# Copy this file to .env.
# For local development the emulator is used, so exact values don't matter —
# except EXPO_PUBLIC_FIREBASE_PROJECT_ID, which must match .firebaserc.

EXPO_PUBLIC_FIREBASE_API_KEY=placeholder
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=placeholder
EXPO_PUBLIC_FIREBASE_PROJECT_ID=gcr26-d76cc
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=placeholder
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=placeholder
EXPO_PUBLIC_FIREBASE_APP_ID=placeholder

# Apple credentials — only needed for `npm run ship` (submit to TestFlight).
# Regular contributors don't need these.
APPLE_ID=
ASC_APP_ID=

# Emulator host — leave as 'localhost' for iOS Simulator / Android Emulator.
# Set to your machine's LAN IP (e.g. 192.168.1.x) if testing on a physical device.
EXPO_PUBLIC_EMULATOR_HOST=localhost
