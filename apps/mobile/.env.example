# Copy this file to .env and fill in your Firebase project values.
# Get these from: Firebase Console → Project Settings → Your apps → Web app config

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Apple credentials for eas submit (npm run ship)
# APPLE_ID: your Apple Developer account email
# ASC_APP_ID: App Store Connect app ID (found in the app's URL on appstoreconnect.apple.com)
APPLE_ID=
ASC_APP_ID=
