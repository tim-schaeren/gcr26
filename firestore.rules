rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Users: own doc is readable/writable by self; admins can read all
    // create is allowed for any authenticated user so signup can write the initial doc
    match /users/{uid} {
      // Own doc, admin, or a teammate (same teamId, non-null)
      allow read:   if isAuth() && (
                      request.auth.uid == uid
                      || isAdmin()
                      || (resource.data.teamId != null
                          && resource.data.teamId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamId)
                    );
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if request.auth.uid == uid || isAdmin();
      allow delete: if isAdmin();
    }

    // Games + nested quests: authenticated users read; admins write
    match /games/{gameId} {
      allow read:  if isAuth();
      allow write: if isAdmin();

      match /quests/{questId} {
        allow read:  if isAuth();
        allow write: if isAdmin();
      }
    }

    // Teams: authenticated users read; admins write
    // Team members may update only the quest progress fields
    match /teams/{id} {
      allow read:   if isAuth();
      allow write:  if isAdmin();
      allow update: if isAuth()
        && request.auth.uid in resource.data.memberIds
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['currentQuestId', 'completedQuestIds', 'finishedAt']);
    }

    // Shop items: authenticated users read; admins write
    match /shopItems/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // Chat messages: any authenticated user can read and post
    match /messages/{id} {
      allow read, write: if isAuth();
    }

    // Broadcasts (admin push messages): authenticated users read; admins write
    match /broadcasts/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // Game settings: authenticated users read; admins write
    match /settings/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // Location trail: players write their own points; only admins read
    match /trail/{trailId} {
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow read:   if isAdmin();
    }

    // Registrations: anyone can submit; only admins manage them
    match /registrations/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
